# Dependencies
frontend/node_modules/
backend/__pycache__/
**/__pycache__/
*.pyc

# Build output
frontend/dist/

# Data (user-generated)
data/images/
data/articles/
data/config.json
data/*.html
!data/.gitkeep
!data/config.json.example

# Dev-only runtime data dir (when running uvicorn from ./backend with
# CONFIG_FILE=backend/data/config.json — see scripts/test_publish_direct.py)
backend/data/

# TypeScript build info (regenerated by editor/tsc on every build)
frontend/tsconfig.tsbuildinfo
frontend/.logs/

# Environment
.env
.env.*

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Development tools
docs/superpowers/
CLAUDE.md
.playwright-mcp/
.playwright-cli/

# Playwright visual test artifacts and auth state
backend/tests/visual/.auth/
backend/tests/visual/_artifacts/

# pip install -e artifacts
*.egg-info/

# Local agent / session state (not portable across machines)
.claude/
.omx/
data/mbdocs/
memory/

# Local scratch dropped at repo root (zipped exports, screenshots, design
# handoffs). Catches every *.png / *.jpg / *.jpeg at the repo root — any image
# meant to ship needs to live under docs/, frontend/, or backend/.
/MBEditor/
/MBEditor.zip
/*.png
/*.jpg
/*.jpeg

# Local git worktrees (per-branch physical checkouts, not portable)
.worktrees/
